{
 "welcomeFile": "index.html",
 "authenticationMethod": "none",
 "routes": [
  {
   "source": "^/odata/v4/admin/(.*)$",
   "target": "/odata/v4/admin/$1",
   "destination": "srv-api",
   "authenticationType": "none"
   
  },
  {
   "source": "^(.*)$",
   "target": "$1",
   "localDir": "webapp",
   "authenticationType": "none"
  }
 ]
}
